# Copy this file to .env and adjust paths for your machine.
# .env is ignored by git so local media paths and tokens do not get committed.

# Folder containing personal test media. Do not commit this folder.
ATE_MEDIA_DIR=sample-media

# Folder for locally cached model files. Setup creates this folder.
# You usually do not put anything here by hand unless you are copying
# already-downloaded models from another machine.
ATE_MODEL_CACHE_DIR=models

# Folder for rendered exports. Do not commit generated exports.
ATE_OUTPUT_DIR=exports

# Offline-first mode. When true, future model adapters should use only local
# files/caches and should not try to download anything during analysis/export.
ATE_OFFLINE_MODE=true

# Optional token for one-time model downloads only. Not needed for normal local
# runs once models are cached, and not needed when using fully local model paths.
HF_TOKEN=

# Preferred runtime device. Use cuda for NVIDIA GPU, cpu for fallback, or auto.
ATE_DEVICE=auto

# Segments below this confidence force subtitle fallback.
ATE_CONFIDENCE_THRESHOLD=0.68

# Optional FFmpeg paths if ffmpeg/ffprobe are not on PATH.
ATE_FFMPEG_BIN=ffmpeg
ATE_FFPROBE_BIN=ffprobe
